# KillaAssistant - Environment Variables
# Copy this file to .env and fill with real values

# Server
PORT=3001
NODE_ENV=development
BACKEND_URL=http://localhost:3001

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# NVIDIA NIM (LLM) - Optional global fallback; users provide their own keys via web panel
# NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Groq (Whisper transcription) - Optional global fallback; users provide their own keys via web panel
# GROQ_API_KEY=your_groq_api_key_here
GROQ_WHISPER_MODEL=whisper-large-v3

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhooks/telegram
TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret-min-32-chars-random

# Google Cloud OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Local dev:  http://localhost:3001/api/auth/callback/google
# Production: https://your-domain.com/api/auth/callback/google
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/callback/google
OAUTH_SUCCESS_REDIRECT_URL=http://localhost:3000/connections

# Frontend URL (CORS allowlist)
# Local dev:  http://localhost:3000
# Production: https://killa-assistant.vercel.app
FRONTEND_URL=http://localhost:3000

# Encryption (AES-256-GCM, 64 hex chars = 32 bytes)
ENCRYPTION_KEY=your_64_char_hex_key_here

# WhatsApp (OpenWA) — single shared bot account
# true = mock mode without Chromium, false = production with Chromium
WHATSAPP_USE_MOCK=true
# Whether to auto-start the WhatsApp bot on server boot (set to "true" in production)
WHATSAPP_AUTOSTART=false
# Secret token required to call /api/whatsapp/admin/start and the admin QR WebSocket.
# Only the operator should know this. Used ONCE to scan the QR and link the bot number.
WHATSAPP_ADMIN_TOKEN=change-me-to-a-long-random-64-char-hex-string

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
